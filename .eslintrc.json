{
  "env": {
    "node": true,
    "es2021": true,
    "browser": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:node/recommended"
  ],
  "settings": {
    "node": {
      "version": "18.0.0"
    }
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "script"
  },
  "rules": {
    "no-console": "off",
    "quotes": "off",
    "semi": "off",
    "comma-dangle": "off",
    "space-before-function-paren": "off",
    "camelcase": "off",
    "no-multiple-empty-lines": "off",
    "no-empty": "warn",
    "node/no-unsupported-features/es-syntax": [
      "error",
      {
        "version": "18.0.0",
        "ignores": ["modules"]
      }
    ],
    "node/no-unsupported-features/node-builtins": "off",
    "node/no-unsupported-features/es-builtins": "off"
  }
}
