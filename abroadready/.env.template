# ==========================================
# AbroadReady FREE APIs Configuration
# ==========================================
# Copy this file as .env and fill in your FREE API keys
# ALL APIs listed here are COMPLETELY FREE with no limits
# ==========================================

# Server Configuration
PORT=3000
SESSION_SECRET=your_long_random_secret_here_run_command_in_guide

# Database
DB_PATH=./database/abroadready.db

# ==========================================
# FREE AI (Hugging Face - No limits!)
# ==========================================
HUGGINGFACE_API_KEY=your_huggingface_token_here

# ==========================================
# FREE Authentication (Google OAuth)
# ==========================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ==========================================
# FREE File Storage (GitHub - Unlimited!)
# ==========================================
GITHUB_STORAGE_REPO=yourusername/yourrepo
GITHUB_TOKEN=

# ==========================================
# FREE Resume Parsing
# ==========================================
RESUME_PARSER_API_KEY=your_resume_parser_key_here

# ==========================================
# FREE Web Scraping
# ==========================================
SCRAPINGBEE_API_KEY=your_scrapingbee_key_here

# ==========================================
# FREE Search (DuckDuckGo - No key needed!)
# ==========================================
SEARCH_API_URL=https://api.duckduckgo.com/

# ==========================================
# FREE Currency Exchange (Frankfurter - No key!)
# ==========================================
FOREX_API_URL=https://api.frankfurter.app/

# ==========================================
# FREE University Data (Hipolabs - No key!)
# ==========================================
UNIVERSITIES_API_URL=http://universities.hipolabs.com/

# ==========================================
# FREE Email (Gmail)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password_here
FROM_EMAIL=noreply@abroadready.in

# ==========================================
# For Production
# ==========================================
# Update GOOGLE_CALLBACK_URL to your production domain
# Update SESSION_SECRET to a strong random string
# All these APIs remain FREE in production!

# Cloudinary (get from https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ==========================================
# REQUIRED: Data APIs
# ==========================================

# University Data (get from https://api.data.gov/signup)
COLLEGE_SCORECARD_API_KEY=your_college_scorecard_key_here

# Currency Exchange (get from https://exchangerate-api.com)
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here

# ==========================================
# OPTIONAL: Enhanced Features
# ==========================================

# Cost of Living Data (get from https://www.numbeo.com/api)
# Leave blank if you don't have this yet
NUMBEO_API_KEY=

# ==========================================
# For Production
# ==========================================
# Update GOOGLE_CALLBACK_URL to your production domain
# Update SESSION_SECRET to a strong random string
# Ensure all API keys are from production accounts
